# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs who have admin access
ADMIN_IDS=123456789,987654321

# Directory for temporary video downloads (will be auto-cleaned)
DOWNLOAD_DIR=./downloads

# Coin system configuration
COINS_PER_DOWNLOAD=2
DAILY_FREE_DOWNLOADS=5
REFERRAL_REWARD_COINS=10

# Rate limiting / anti-spam
COOLDOWN_SECONDS=10
MAX_DOWNLOADS_PER_HOUR=30
QUEUE_MAX_SIZE=20

# Paths (leave default if in system PATH)
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Firebase Realtime Database
USE_FIREBASE=true
FIREBASE_PROJECT_ID=club-fire-11
FIREBASE_DATABASE_URL=https://club-fire-11-default-rtdb.firebaseio.com

# For local: put service account JSON file here
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# For cloud (Render, Railway, etc.): paste the entire service account JSON as this env var (no file needed)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ... full json ...}

FIREBASE_API_KEY=AIzaSyDsDwx3pB3Eg-vb8C6t8wOQDOdON8N5Yqo
FIREBASE_APP_ID=1:519098949332:web:563a47157dd9e5ba50a541

# Logging level: debug, info, warn, error
LOG_LEVEL=info
